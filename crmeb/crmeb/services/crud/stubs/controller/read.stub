    /**
     * 查看
     * @param $id
     * @return \think\Response
     * @date {%DATE%}
     */
    public function read($id)
    {
        if (!$id) {
            return app('json')->fail('参数错误');
        }

        $info = $this->service->get($id, [{%FIELD%}], {%WITH%});
        if (!$info) {
            return app('json')->fail('数据不存在');
        }

        return app('json')->success($info->toArray());
    }
