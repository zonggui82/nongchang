<view class="time" style="{{(justifyLeft)}}"><block wx:if="{{tipText}}"><text class="red">{{tipText}}</text></block><block wx:if="{{isDay===true}}"><text class="styleAll" style="{{$root.s0}}">{{day}}</text></block><block wx:if="{{dayText}}"><text class="timeTxt red" style="{{$root.s1}}">{{dayText}}</text></block><text class="styleAll" style="{{$root.s2}}">{{hour}}</text><block wx:if="{{hourText}}"><text class="timeTxt red" style="{{$root.s3}}">{{hourText}}</text></block><text class="styleAll" style="{{$root.s4}}">{{minute}}</text><block wx:if="{{minuteText}}"><text class="timeTxt red" style="{{$root.s5}}">{{minuteText}}</text></block><text class="styleAll" style="{{$root.s6}}">{{second}}</text><block wx:if="{{secondText}}"><text class="timeTxt red" style="{{$root.s7}}">{{secondText}}</text></block></view>